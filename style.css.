/* ==========================================================================
   style.css - Estilos Globais e Variáveis da Santo Look
   Objetivo: Definir a identidade visual Premium, Glamour e Feminina.
   ========================================================================== */

/* 1. Importação de Fontes (Elegância e Modernidade) */
/* Serifada para Títulos: Cormorant Garamond (substituindo Playfair para mais 'glamour') */
/* Sans-Serif para Corpo: Montserrat */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Montserrat:wght@300;400;600&display=swap');

/* 2. Variáveis de Design (Paleta de Cores e Tipografia) */
:root {
    /* Cores Principais (Baseadas no Prompt e Logo) */
    --cor-fundo: #FAFAF8;       /* Off-white cremoso para fundo */
    --cor-texto-escuro: #1A1A1A; /* Quase preto para legibilidade premium */
    --cor-primaria: #D4A396;      /* Rosa Seco Sofisticado (do logo) */
    --cor-primaria-claro: #E8CAC1; /* Tom mais claro do rosa para hovers */
    --cor-destaque: #C48F82;     /* Tom mais escuro do rosa para detalhes */
    
    /* Cores de Botão (WhatsApp e CTAs) */
    --cor-whatsapp: #25D366;
    --cor-whatsapp-hover: #1DA851;
    --gradiente-premium: linear-gradient(135deg, var(--cor-primaria) 0%, var(--cor-destaque) 100%);

    /* Tipografia */
    --fonte-titulos: 'Cormorant Garamond', serif;
    --fonte-corpo: 'Montserrat', sans-serif;

    /* Espaçamento e Bordas (Suavidade) */
    --espacamento-padrao: 20px;
    --borda-arredondada: 15px; /* Bordas suaves como no Figma */
    --borda-card: 20px;
    
    /* Transições (Fluidez) */
    --transicao-suave: all 0.4s ease-in-out;
}

/* 3. Reset Básico (Para consistência) */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: var(--fonte-corpo);
    background-color: var(--cor-fundo);
    color: var(--cor-texto-escuro);
    line-height: 1.6;
    overflow-x: hidden; /* Evita barra de rolagem horizontal indesejada */
}

a {
    text-decoration: none;
    color: inherit;
    transition: var(--transicao-suave);
}

ul {
    list-style: none;
}

img {
    max-width: 100%;
    display: block;
}

/* 4. Estilos Utilitários (Para usar no HTML) */
.container {
    width: 90%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--espacamento-padrao);
}

/* Títulos Premium */
.titulo-premium {
    font-family: var(--fonte-titulos);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--cor-texto-escuro);
    margin-bottom: 10px;
}

.subtitulo-premium {
    font-family: var(--fonte-titulos);
    font-weight: 400;
    font-style: italic;
    color: var(--cor-primaria);
    font-size: 1.2rem;
    margin-bottom: var(--espacamento-padrao);
}

/* Botão Principal Estilizado (Conforme Figma/Prompt) */
.btn-premium {
    display: inline-block;
    padding: 15px 40px;
    background-color: var(--cor-texto-escuro); /* Preto como no Figma image_5.png */
    color: #FFF;
    font-family: var(--fonte-corpo);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 1px;
    border-radius: 50px; /* Totalmente arredondado */
    transition: var(--transicao-suave);
    border: 1px solid var(--cor-texto-escuro);
}

.btn-premium:hover {
    background-color: transparent;
    color: var(--cor-texto-escuro);
}

/* Animação Base para o Efeito de Rolagem (Smooth Reveal) */
.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease-out;
}

.reveal.active {
    opacity: 1;
    transform: translateY(0);
}
